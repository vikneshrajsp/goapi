{
  "id": null,
  "uid": "goapi-slo-error-budget",
  "title": "GoAPI SLO / Error Budget",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Availability (Success vs 5xx)",
      "description": "Treats server errors (5xx) as failed. Uses job=goapi only. Empty 5xx series yield 100% via or vector(0).",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "1 - (((sum(rate(goapi_http_requests_total{job=\"goapi\",status=~\"5..\"}[5m])) or vector(0)) / clamp_min(sum(rate(goapi_http_requests_total{job=\"goapi\"}[5m])), 1)))",
          "legendFormat": "success ratio (1 - 5xx/all)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.995 },
              { "color": "green", "value": 0.999 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Availability SLO Target",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "0.999",
          "legendFormat": "target"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "title": "Remaining Error Budget Fraction (rolling 7d)",
      "description": "Uses a 7-day window so single-node Prometheus retention can stay aligned. Tune if you extend TSDB retention.",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "clamp_min(1 - (((sum(rate(goapi_http_requests_total{job=\"goapi\",status=~\"5..\"}[7d])) or vector(0)) / clamp_min(sum(rate(goapi_http_requests_total{job=\"goapi\"}[7d])), 1)) / (1 - 0.999)), 0)",
          "legendFormat": "budget remaining"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 }
    },
    {
      "id": 4,
      "title": "Latency Objective (P95 < 300ms)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route, method) (rate(goapi_http_request_duration_seconds_bucket{job=\"goapi\"}[5m])))",
          "legendFormat": "p95 · {{route}} {{method}}"
        },
        {
          "expr": "0.3",
          "legendFormat": "SLO threshold (0.3s)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 5,
      "title": "Burn Rate (1h window)",
      "description": "Burn rate > 1 means consuming error budget faster than sustained SLO allows (here vs 99.9%).",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "((sum(rate(goapi_http_requests_total{job=\"goapi\",status=~\"5..\"}[1h])) or vector(0)) / clamp_min(sum(rate(goapi_http_requests_total{job=\"goapi\"}[1h])), 1)) / (1 - 0.999)",
          "legendFormat": "1h burn rate"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "id": 6,
      "title": "Burn Rate (6h window)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "((sum(rate(goapi_http_requests_total{job=\"goapi\",status=~\"5..\"}[6h])) or vector(0)) / clamp_min(sum(rate(goapi_http_requests_total{job=\"goapi\"}[6h])), 1)) / (1 - 0.999)",
          "legendFormat": "6h burn rate"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "id": 7,
      "title": "Latency SLO (requests slower than 300ms / sec)",
      "description": "Difference between cumulative histogram rates at +Inf and at 300ms (requires app histogram bucket at 0.3s).",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(goapi_http_request_duration_seconds_bucket{job=\"goapi\",le=\"+Inf\"}[5m])) - sum(rate(goapi_http_request_duration_seconds_bucket{job=\"goapi\",le=\"0.3\"}[5m]))",
          "legendFormat": "estimated slow requests / sec (>300ms)"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    }
  ]
}
