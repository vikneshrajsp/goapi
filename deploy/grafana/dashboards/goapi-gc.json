{
  "id": null,
  "uid": "goapi-gc",
  "title": "GoAPI GC Deep Dive",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Heap In Use",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "go_memstats_heap_inuse_bytes",
          "legendFormat": "heap in use"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Heap Objects",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "go_memstats_heap_objects",
          "legendFormat": "objects"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "title": "GC Cycles / sec",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(go_gc_cycles_automatic_gc_cycles_total[5m])",
          "legendFormat": "gc cycles/s"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "title": "GC Pause (total seconds / sec)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(go_gc_duration_seconds_sum[5m])",
          "legendFormat": "pause seconds/s"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}
